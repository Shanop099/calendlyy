generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                 @db.VarChar(255)
  email                 String                 @unique @db.VarChar(255)
  username              String                 @unique @db.VarChar(100)
  timezone              String                 @default("UTC") @db.VarChar(100)
  created_at            DateTime               @default(now()) @db.Timestamptz()
  event_types           EventType[]
  availability_schedules AvailabilitySchedule[]

  @@map("users")
}

model EventType {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(100)
  duration    Int
  description String?
  color       String    @default("#006BFF") @db.VarChar(7)
  is_active   Boolean   @default(true)
  location    String?   @db.VarChar(255)
  created_at  DateTime  @default(now()) @db.Timestamptz()
  user        User      @relation(fields: [user_id], references: [id])
  meetings    Meeting[]

  @@map("event_types")
}

model AvailabilitySchedule {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String             @db.Uuid
  name       String             @db.VarChar(255)
  timezone   String             @db.VarChar(100)
  is_default Boolean            @default(false)
  created_at DateTime           @default(now()) @db.Timestamptz()
  user       User               @relation(fields: [user_id], references: [id])
  rules      AvailabilityRule[]

  @@map("availability_schedules")
}

model AvailabilityRule {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schedule_id  String               @db.Uuid
  day_of_week  Int
  start_time   String               @db.VarChar(8)
  end_time     String               @db.VarChar(8)
  is_available Boolean              @default(true)
  schedule     AvailabilitySchedule @relation(fields: [schedule_id], references: [id])

  @@map("availability_rules")
}

model Meeting {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type_id  String    @db.Uuid
  invitee_name   String    @db.VarChar(255)
  invitee_email  String    @db.VarChar(255)
  start_time     DateTime  @db.Timestamptz()
  end_time       DateTime  @db.Timestamptz()
  status         String    @default("active") @db.VarChar(20)
  cancel_reason  String?
  notes          String?
  created_at     DateTime  @default(now()) @db.Timestamptz()
  event_type     EventType @relation(fields: [event_type_id], references: [id])

  @@map("meetings")
}
